# VideoSDK credentials — copy to .env and fill in real values.
# NEVER commit .env to git.

VIDEOSDK_API_KEY=your_videosdk_api_key_here
VIDEOSDK_SECRET=your_videosdk_secret_here

# VideoSDK REST base URL (default is correct for production)
VIDEOSDK_API_ENDPOINT=https://api.videosdk.live

# Comma-separated allowed origins. Use * to allow all (dev/ngrok only).
FRONTEND_ORIGIN=http://localhost:3001,https://your-app.vercel.app

# Flask port (default 5000)
PORT=5000

# Set to 1 only in local dev — never in production
FLASK_DEBUG=0
